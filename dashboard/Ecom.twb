      <column caption='Revenue' datatype='real' name='[Calculation_1964336039182336]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[UnitPrice] * [Quantity]' />
      </column>
      <column caption='Repeat' datatype='integer' name='[Calculation_1964336120786955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF { FIXED [CustomerID] : COUNTD([InvoiceNo]) } &gt; 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_1964336126816272]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1964336120786955] = 1 THEN &quot;Onetime&quot;&#13;&#10;ELSE &quot;Repeat&quot;&#13;&#10;END' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1964336128544785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    { FIXED [InvoiceNo] : SUM([Calculation_1964336039182336])}&#13;&#10;)' />
      </column>
      <column caption='Valid Sales' datatype='real' name='[Calculation_1964336130695187]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Quantity] &gt; 0 THEN [Calculation_1964336039182336] END' />
      </column>
      <column caption='Returns' datatype='real' name='[Calculation_2169944839221248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Quantity] &lt; 0 THEN [Calculation_1964336039182336] END&#13;&#10;)' />
      </column>
      <column caption='Show Returns' datatype='string' name='[Calculation_2169944839892993]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_2169944839221248]) OR [Calculation_2169944839221248] = 0 THEN&#13;&#10;    &quot;N/A&quot;&#13;&#10;ELSE&#13;&#10;    STR(ROUND(ABS([Calculation_2169944839221248]), 2))&#13;&#10;END' />
      </column>
